{
  "name": "nuxt-travel-log",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:db": "turso dev --db-file ./local.db",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "dbseed": "tsx --env-file=.env app/utils/injest-csv.ts",
    "db:setup": "dbm && db:seed",
    "dbg": "drizzle-kit generate",
    "dbm": "drizzle-kit migrate",
    "dbk": "drizzle-kit studio",
    "dbs": "drizzle-kit generate && drizzle-kit migrate && tsx --env-file=.env app/utils/injest-csv.ts "
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/icon": "2.2.1",
    "@nuxtjs/color-mode": "4.0.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/vite": "^4.2.2",
    "better-auth": "^1.5.6",
    "csv": "^6.5.1",
    "csv-parse": "^6.2.1",
    "csv-parser": "^3.2.0",
    "daisyui": "^5.5.19",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.1.0",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@iconify-json/tabler": "^1.2.33",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0"
  },
  "lint-staged": {
    "*": "pnpm lint"
  }
}
